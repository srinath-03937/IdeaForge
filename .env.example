# ===========================================
# IDEA FORGE - ENVIRONMENT VARIABLES
# ===========================================
# Copy and paste these variables during deployment

# ===========================================
# FIREBASE CONFIGURATION
# ===========================================
# Get these values from Firebase Console > Project Settings > General
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# ===========================================
# GEMINI AI CONFIGURATION
# ===========================================
# Get API key from Google AI Studio
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ===========================================
# GITHUB SEARCH CONFIGURATION
# ===========================================
# Option 1: Use GitHub Actions environment variable (RECOMMENDED)
# Set GITHUB_TOKEN in your deployment platform environment variables
# No need to expose tokens in your codebase

# Option 2: Use personal access token (for local development)
# Get token from: GitHub Settings > Developer settings > Personal access tokens
# WARNING: Never commit tokens to version control
# GITHUB_TOKEN=your_github_personal_access_token_here

# ===========================================
# DEPLOYMENT SPECIFIC
# ===========================================
# Production environment
NODE_ENV=production

# Application URLs
VITE_APP_URL=https://your-domain.com
VITE_API_URL=https://your-domain.com/api

# ===========================================
# INSTRUCTIONS FOR DIFFERENT PLATFORMS
# ===========================================

# VERCEL DEPLOYMENT:
# 1. Go to Vercel dashboard > Project > Settings > Environment Variables
# 2. Add all the above variables (except NODE_ENV)
# 3. Redeploy your application

# NETLIFY DEPLOYMENT:
# 1. Go to Netlify dashboard > Site > Build & deploy > Environment
# 2. Add all the above variables as environment variables
# 3. Trigger new build and deploy

# DOCKER DEPLOYMENT:
# 1. Create .env.production file with these variables
# 2. Use docker secrets or environment file mounting
# 3. Build and deploy container

# AWS S3/AMPLIFY:
# 1. Go to AWS Amplify console > App settings > Environment variables
# 2. Add all the above variables
# 3. Push and deploy

# ===========================================
# SECURITY NOTES
# ===========================================
# - Never commit .env files to version control
# - Use different API keys for development and production
# - Regularly rotate API keys
# - Use environment-specific configurations
# - Store sensitive data in environment variables only

# ===========================================
# DEVELOPMENT SETUP
# ===========================================
# Create .env.local file for local development:
cp .env.example .env.local
# Then add your development keys to .env.local

# ===========================================
# FIREBASE SETUP GUIDE:
# ===========================================
# 1. Go to https://console.firebase.google.com
# 2. Create new project or select existing
# 3. Go to Project Settings > General
# 4. Copy Web API Key
# 5. Enable Authentication (Email/Password, Google, Anonymous)
# 6. Enable Firestore Database
# 7. Configure Security Rules

# ===========================================
# GEMINI SETUP GUIDE:
# ===========================================
# 1. Go to https://aistudio.google.com
# 2. Create new API key or use existing
# 3. Enable Gemini API
# 4. Copy API key
# 5. Set appropriate usage limits

# ===========================================
# QUICK COPY-PASTE SECTION
# ===========================================
# Copy these lines for immediate deployment:
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_APP_ID=1:123456789:web
VITE_GEMINI_API_KEY=AIzaSy...
VITE_APP_URL=https://your-domain.com

